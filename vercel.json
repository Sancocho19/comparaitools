{
  "crons": [
    {
      "path": "/api/auto-generate?secret=comparaitools-secret-2026-xyz",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/auto-generate?secret=comparaitools-secret-2026-xyz",
      "schedule": "0 18 * * *"
    }
  ],
  "headers": [
    {
      "source": "/blog/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/tools/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
